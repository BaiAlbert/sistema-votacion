# Ruta: /etc/nginx/sites-available/sistema-votacion
server {
    listen 80;
    server_name _; # Esto hace que responda a cualquier IP o dominio que le llegue

    # 1. Enrutar el Frontend (React)
    location / {
        proxy_pass http://192.168.50.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 2. Enrutar el Backend (PHP) usando el prefijo /api/
    # La barra al final de 8000/ es importante. Hace que Nginx elimine el "/api"
    # antes de pasárselo al contenedor de PHP.
    location /api/ {
        proxy_pass http://192.168.50.1:8000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 3. Enrutar phpMyAdmin (Opcional, pero cómodo)
    location /pma/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        proxy_pass http://192.168.50.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # 4. Enrutar Portainer (Interfaz de Docker)
    # La barra al final de 9000/ es obligatoria
    location /portainer/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        proxy_pass http://192.168.50.1:9000/;

        # Cabeceras básicas
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Cabeceras para que funcione la terminal de Portainer (WebSockets)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
    }

    # 5. Enrutar Netdata individualmente

    # Netdata del manager
    location /netdata-manager/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        rewrite ^/netdata-master(/(.*))$ /$2 break;

        proxy_pass http://192.168.50.1:19999/;
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr;

        proxy_http_version 1.1; 
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Netdata del nodo DB
    location /netdata-db/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        rewrite ^/netdata-db(/(.*))$ /$2 break;

        proxy_pass http://192.168.50.2:19999/;
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr;

        proxy_http_version 1.1; 
        proxy_set_header Upgrade $http_upgrade; 
        proxy_set_header Connection "upgrade";
    }

    # Netdata del worker 1
    location /netdata-worker1/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        rewrite ^/netdata-w1(/(.*))$ /$2 break;

        proxy_pass http://192.168.50.3:19999/;
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr;

        proxy_http_version 1.1; 
        proxy_set_header Upgrade $http_upgrade; 
        proxy_set_header Connection "upgrade";
    }

    # Netdata del worker 2
    location /netdata-worker2/ {
        # Seguridad para que solo la ip publica de mi maquina manager pueda entrar
        # allow TU_IP_PUBLICA;
        # deny all;

        rewrite ^/netdata-w2(/(.*))$ /$2 break;

        proxy_pass http://192.168.50.4:19999/;
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr;

        proxy_http_version 1.1; 
        proxy_set_header Upgrade $http_upgrade; 
        proxy_set_header Connection "upgrade";
    }
}